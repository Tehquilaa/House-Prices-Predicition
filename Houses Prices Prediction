gged.values())\ndf_tr_wout = df_tr.drop(index=all_outlier_idx)","metadata":{"execution":{"iopub.status.busy":"2026-04-17T23:08:26.356660Z","iopub.execute_input":"2026-04-17T23:08:26.357069Z","iopub.status.idle":"2026-04-17T23:08:26.365541Z","shell.execute_reply.started":"2026-04-17T23:08:26.356954Z","shell.execute_reply":"2026-04-17T23:08:26.364732Z"},"trusted":true},"outputs":[],"execution_count":171},{"cell_type":"markdown","source":"## 8.2 Create New Features","metadata":{}},{"cell_type":"code","source":"def new_features(df):\n        \n    df['SameMaterial'] = (df['Exterior1st'] == df['Exterior2nd']).astype(int)\n    df['HasBasement'] = (df.BsmtQual != 'None').astype(int)\n    df['HasGarage'] = (df['GarageType'] != 'None').astype(int)\n    df['WasRemodeled'] = (df['YearRemodAdd'] != df['YearBuilt']).astype(int)\n   \n    # HouseStyle\n    levels_map = {\n    '1Story': 1, '1.5Fin': 1.5, '1.5Unf': 1.5,\n    '2Story': 2, '2.5Fin': 2.5, '2.5Unf': 2.5,\n    'SFoyer': 1, 'SLvl': 1.5\n    }\n    \n    df['IsSplitLevel'] = df['HouseStyle'].isin(['SFoyer', 'SLvl']).astype(int)\n    df['NumLevels'] = df['HouseStyle'].map(levels_map).fillna(1)\n    df['IsFinished'] = np.where(df['HouseStyle'].str.contains('Unf', na=False), 0, 1)\n    # End HouseStyle\n    \n    df['HasFireplace'] = (df['Fireplaces'] > 0).astype(int)\n    df['TotalBath'] = df['FullBath'] + df['BsmtFullBath'] + 0.5 * (df['HalfBath'] + df['BsmtHalfBath'])  \n    df['TotalPorchSF'] = df['WoodDeckSF'] + df['OpenPorchSF'] + df['EnclosedPorch'] + df['ScreenPorch'] \n    df['OverallC_is5'] =  (df['OverallCond'] == 5).astype(int)\n    df['TotalBuiltArea'] = df['GrLivArea'] + df['TotalBsmtSF'] + df['GarageArea']\n\n    return df\n\n","metadata":{"execution":{"iopub.status.busy":"2026-04-17T23:08:26.366641Z","iopub.execute_input":"2026-04-17T23:08:26.366923Z","iopub.status.idle":"2026-04-17T23:08:26.375387Z","shell.execute_reply.started":"2026-04-17T23:08:26.366897Z","shell.execute_reply":"2026-04-17T23:08:26.374156Z